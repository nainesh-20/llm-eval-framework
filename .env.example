# ── LLM API Keys ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub Integration (for PR comment reporting) ─────────────────────────────
# Required only when running the GitHub Actions CI step locally
GITHUB_TOKEN=ghp_...
GITHUB_REPOSITORY=your-username/llm-eval-framework
PR_NUMBER=1

# ── Eval Configuration ────────────────────────────────────────────────────────
# Override the default config file path
EVAL_CONFIG_PATH=configs/eval.yaml

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
